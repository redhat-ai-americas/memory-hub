FROM registry.redhat.io/ubi9/python-311:latest

WORKDIR /opt/app-root/src

# Install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy memoryhub core library from parent project
COPY --chown=1001:0 memoryhub-core/ ./memoryhub-core/
RUN pip install --no-cache-dir ./memoryhub-core/

# Copy MCP server application code
COPY --chown=1001:0 src/ ./src/
COPY --chown=1001:0 conftest.py ./

# Fix permissions for OpenShift arbitrary UIDs
RUN find ./src -name "*.py" -exec chmod 644 {} \;

# Set environment for HTTP transport
ENV MCP_TRANSPORT=http \
    MCP_HTTP_HOST=0.0.0.0 \
    MCP_HTTP_PORT=8080 \
    MCP_HTTP_PATH=/mcp/

USER 1001

# Use FastMCP 3 entry point
CMD ["python", "-m", "src.main"]
